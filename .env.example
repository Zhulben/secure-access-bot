# ============================================================
# Переменные окружения для secure_access_bot
# Скопируйте этот файл в .env и заполните значения
# ============================================================

# --- Telegram Bot ---
# Получить у @BotFather
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# --- База данных ---
# Формат: postgresql+asyncpg://user:password@host:port/dbname
# Для Docker Compose хост = postgres (имя сервиса)
DATABASE_URL=postgresql+asyncpg://botuser:botpassword@postgres:5432/secure_access_bot

# --- Администраторы ---
# Telegram ID администраторов через запятую
# Узнать свой ID можно у @userinfobot
ADMIN_IDS=123456789,987654321

# --- Логирование ---
# Уровень: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# --- Генератор ключей ---
# Префикс генерируемых ключей
KEY_PREFIX=KEY

# Длина случайной части (рекомендуется кратно 4)
KEY_RANDOM_LENGTH=12
